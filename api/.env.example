# Server Configuration
PORT=3000
NODE_ENV=development

# Redis Configuration
# Persistence: AOF (everysec) + RDB (configured in redis.conf)
# Memory limit: 256MB with allkeys-lru eviction policy
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional: REDIS_PASSWORD=your_password_if_required

# API Authentication
# Default: logotestkey
API_KEY=logotestkey

# AI Configuration (x-aio / OpenCode AI)
# Required for Excel trademark extraction feature
# Get your API key from: https://x-aio.com
XAIO_API_KEY=your_api_key_here
XAIO_BASE_URL=https://api.x-aio.com/v1
XAIO_MODEL=kimi-k2.5

# Alternative: OpenAI Configuration (if using OpenAI instead)
# OPENAI_API_KEY=your_openai_key_here

# Cache Configuration
CACHE_TTL_HOURS=24

# Query Configuration
QUERY_DELAY_MS=5000
QUERY_TIMEOUT_MS=120000
MAX_RETRIES=3
